{
  "enabled": true,
  "name": "需求澄清完成提醒",
  "description": "当需求澄清文档创建后，自动提醒产品经理进入方案设计阶段",
  "version": "2",
  "when": {
    "type": "fileCreated",
    "patterns": [
      "product-specs/*/产品-需求澄清.md"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "需求澄清文档已创建完成。请提醒用户：1) 检查需求澄清的质量（痛点是否量化、四维评估是否合理、需求类型和特征标签是否准确）；2) 确认无误后，说「进入下一阶段」即可进入方案设计。"
  }
}
