{
  "toolsSettings": {
    "execute_bash": {
      "allowedCommands": [
        "python .*",
        "python3 .*",
        "pip install .*",
        "pip3 install .*",
        "pip list.*",
        "pip freeze.*",
        "pytest .*",
        "python -m pytest.*",
        "ls.*",
        "cat .*",
        "find .*",
        "grep .*",
        "git status.*",
        "git log.*",
        "git diff.*",
        "git branch.*",
        "mkdir .*",
        "cp .*",
        "mv .*",
        "echo .*",
        "pwd",
        "which .*",
        "npm .*",
        "node .*",
        "head .*",
        "tail .*",
        "wc .*"
      ],
      "deniedCommands": [
        "rm -rf /.*",
        "sudo .*"
      ],
      "autoAllowReadonly": true
    },
    "fs_read": {
      "allowedPaths": ["./**"]
    },
    "fs_write": {
      "allowedPaths": ["./**"]
    }
  }
}
